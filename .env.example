# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# FRED API (https://fredaccount.stlouisfed.org/apikeys)
FRED_API_KEY=your-32-character-key-here

# Anthropic (Claude AI narratives)
ANTHROPIC_API_KEY=your-anthropic-key-here

# AWS — prefer `aws configure --profile quant-lab` over these,
# but some tools need them as env vars (e.g. boto3 in CI):
# AWS_PROFILE=quant-lab
# AWS_REGION=us-east-1

# Bond Pricing Engine
DATABASE_URL=sqlite+aiosqlite:///engine.db
S3_BUCKET=finbytes-quant-lab-data
